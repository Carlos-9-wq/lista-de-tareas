using Microsoft.AspNetCore.Mvc;
using lista_de_tareas.Models;
using System.Collections.Generic;

namespace lista_de_tareas.Controllers
{
    public class TareasController : Controller
    {
        private List<TareaEntity> Tareas;

        public TareasController()
        {
            Tareas = new List<TareaEntity>
            {
                new TareaEntity { Id = 1, Titulo = "Limpiar casa", Descripcion = "Limpiar baños y cuartos", Estatus = false },
                new TareaEntity { Id = 2, Titulo = "Comprar", Descripcion = "Comprar comida", Estatus = true }
            };
        }

        public IActionResult Index()
        {
            return View(Tareas);
        }
    }
}