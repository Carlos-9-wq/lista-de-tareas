using System.Collections;
using System.Collections.Generic;
using System.Linq;
using System.Reflection;
using lista_de_tareas.Models;

namespace lista_de_tareas.Data
{
    // Simple in-memory DataContext to satisfy controller usage without EF Core.
    public class DataContext
    {
        public FakeDbSet<TareaEntity> Tareas { get; } = new FakeDbSet<TareaEntity>();

        // Keep SaveChanges for compatibility with existing controller code.
        public int SaveChanges() => 0;
    }

    // Minimal in-memory DbSet-like collection with LINQ support and required methods.
    public class FakeDbSet<T> : IEnumerable<T> where T : class
    {
        private readonly List<T> _data = new List<T>();

        public void Add(T item) => _data.Add(item);

        public bool Remove(T item) => _data.Remove(item);

        // Update is a no-op for in-memory reference types; controller replaces properties directly.
        public void Update(T item)
        {
            // no-op
        }

        // Find by integer Id property (common convention in this project).
        public T? Find(int id)
        {
            var prop = typeof(T).GetProperty("Id", BindingFlags.Public | BindingFlags.Instance);
            if (prop == null) return null;

            return _data.FirstOrDefault(x =>
            {
                var val = prop.GetValue(x);
                return val is int i && i == id;
            });
        }

        // Expose LINQ methods by implementing IEnumerable<T>.
        public IEnumerator<T> GetEnumerator() => _data.GetEnumerator();

        IEnumerator IEnumerable.GetEnumerator() => _data.GetEnumerator();

        // Helper to allow callers to get a snapshot list.
        public List<T> ToList() => new List<T>(_data);
    }
}
